# OpenAI Configuration
OPENAI_API_KEY=***REMOVED***your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.7

# Project Configuration
PROJECT_NAME=QA Testing Agent
TEST_INPUT_FOLDER=./test_inputs
REPORT_OUTPUT_FOLDER=./reports
SCREENSHOTS_FOLDER=./reports/screenshots
BASE_URL=https://your-app.example.com
LOGIN_EMAIL=user@example.com
LOGIN_PASSWORD=change_me
LOGIN_EMAIL_SELECTOR=input[name="email"]
LOGIN_PASSWORD_SELECTOR=input[name="password"]
LOGIN_BUTTON_SELECTOR=button[type="submit"]
POST_LOGIN_SELECTOR=.dashboard-root

# Browser Configuration
BROWSER_TYPE=chrome  # Options: chrome, firefox, webkit
HEADLESS=false
SCREENSHOT_ON_FAILURE=true
IMPLICIT_WAIT=10
CHROME_BINARY=C:\\Path\\To\\chromium.exe
TEST_TIMEOUT_SECONDS=300

# Agent Configuration
MAX_RETRY_LOOPS=3
INCLUDE_MOCK_DATA_GENERATION=true
PARALLEL_EXECUTION=false
EXECUTE_REJECTED_TESTS=false
