# ============================================================
# QA Testing Agent - Complete .env Configuration
# ============================================================

# OpenAI
OPENAI_API_KEY=***REMOVED***
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.3

# ============================================================
# Target Application
# ============================================================
BASE_URL=https://dev.mirrix.app/login
LOGIN_EMAIL=lakshmi@unitofmeasure.com
LOGIN_PASSWORD=***REMOVED***
EMAIL_FIELD_LABEL=Email
PASSWORD_FIELD_LABEL=Password
LOGIN_BUTTON_PATTERN=log.?in|sign.?in

# Where to go after login
FEATURE_URL=https://dev.mirrix.app/assets

# ============================================================
# STORY PRECONDITIONS
# Values can be either:
#   - Plain text: "Click Filters" (vague, less reliable)
#   - _app_* calls: "_app_open_filter_panel(page)" (precise, uses real selectors)
#
# Use _app_* function names from the helper library. These map directly to
# proven selectors captured in recorded_flow.py.
# ============================================================
STORY_PRECONDITIONS_JSON='{"CSV-51415": ["Click Filters", "Expand Tags"], "Auto-Populate Additional Tags in Filter After Results Load": ["Click Filters", "Expand Tags"], "CSV-38683": ["Click Filters", "Expand Tags"], "Reload Filters When OR operator Is Selected in Advanced Filter": ["Click Filters", "Expand Tags"]}'

# ============================================================
# Browser
# ============================================================
HEADLESS=false
BROWSER_TYPE=chromium
SCREENSHOT_ON_FAILURE=true
ELEMENT_TIMEOUT_MS=10000
TEST_TIMEOUT_MS=300000
TEST_TIMEOUT_SECONDS=300

# ============================================================
# Selector Map — auto-generated from recorded_flow.py
# Place recorded_flow.py in ./ui_snapshot/ and it builds automatically.
# ============================================================
ENABLE_PAGE_INSPECTION=true
UI_SNAPSHOT_FOLDER=./ui_snapshot
SELECTOR_MAP_FILE=selector_map.json
RECORDED_FLOW_FILE=recorded_flow.py

# ============================================================
# Pipeline
# ============================================================
TEST_INPUT_FOLDER=./test_inputs
REPORT_OUTPUT_FOLDER=./reports
SCREENSHOTS_FOLDER=./reports/screenshots
MAX_RETRY_LOOPS=3
EXECUTE_REJECTED_TESTS=true
PARALLEL_EXECUTION=false
INCLUDE_MOCK_DATA_GENERATION=false
